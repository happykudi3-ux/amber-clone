# Groq API key for LLM calls (chat + sentiment scoring)
GROQ_API_KEY=

# Auto-injected by Vercel when you add the Postgres/Neon integration - don't set manually
DATABASE_URL=

# Random secret string - protects the cron endpoint from being triggered by randoms
CRON_SECRET=

# If you add JWT auth on the chat widget later (reuse your ARIA pattern)
JWT_SECRET=
